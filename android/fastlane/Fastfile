default_platform(:android)

platform :android do
  desc "Build a release APK"
  lane :build_apk do
    Dir.chdir("../..") do
      sh("flutter", "build", "apk", "--release")
    end

    apk_path = File.expand_path("../../build/app/outputs/flutter-apk/app-release.apk")

    if File.exist?(apk_path)
      UI.success("✅ APK built successfully at: #{apk_path}")
    else
      UI.user_error!("❌ APK not found at expected path: #{apk_path}")
    end
  end
end
